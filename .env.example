# GitHub OAuth App (Phase 3+)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Session signing (generate: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=change-me-to-a-long-random-string

# PostgreSQL (e.g. Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: scan without login (Postman / dev)
SCANNER_GITHUB_TOKEN=

# Cache TTL in seconds (default 30 minutes)
CACHE_TTL_SECONDS=1800

# Path to GSSoC project catalog (repo root)
PROJECTS_JSON_PATH=projects.json

# Scan tuning
SCAN_CONCURRENCY=3
MAX_ISSUES_PER_REPO=500
# Treat scan as dead if no progress for this many seconds (crash/orphan recovery)
SCAN_STALE_SECONDS=180

# App
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:5173
